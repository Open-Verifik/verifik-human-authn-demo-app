# Local dev server port (used by `pnpm dev`, Electron, and root `pnpm dev:desktop`).
# If unset, the app defaults to 3000. Copy to `.env` / `.env.local` to override (e.g. 3017). See README.
PORT=3017

# Canonical public URL (used for sitemap, robots.txt, OG tags, llms.txt).
# Set to your production domain in deployment; defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://humanauthn.verifik.co
