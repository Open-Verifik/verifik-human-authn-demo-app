  "apiBullet3": "\u092c\u093f\u0928\u093e \u091a\u0947\u0939\u0930\u093e \u091b\u0935\u093f \u0915\u0947 \u092a\u094d\u0930\u092e\u093e\u0923 \u0915\u0940 \u091c\u093e\u0902\u091a \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f Preview HumanID \u0921\u0947\u092e\u094b (previewHumanId) \u092f\u093e \u0909\u092a\u0930 \u0932\u093f\u0902\u0915 \u0915\u093f\u090f Preview ZelfProof \u0917\u093e\u0907\u0921 \u0916\u094b\u0932\u0947\u0902\u0964",
