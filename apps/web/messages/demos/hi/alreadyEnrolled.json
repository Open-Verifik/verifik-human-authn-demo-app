{
  "title": "\u092f\u0939 \u091a\u0947\u0939\u0930\u093e \u092a\u0939\u0932\u0947 \u0938\u0947 \u0928\u093e\u092e\u093e\u0902\u0915\u093f\u0924 \u0939\u0948",
  "body": "API \u0928\u0947 <code>person_already_set</code> \u0932\u094c\u091f\u093e\u092f\u093e\u0964 \u092e\u0947\u0932 \u0916\u093e\u0924\u0947 \u091a\u0947\u0939\u0930\u0947 \u0935\u093e\u0932\u093e \u0915\u094b\u0908 \u092a\u0939\u0932\u0947 \u0938\u0947 \u0906\u092a\u0915\u0947 \u092a\u094d\u0930\u094b\u091c\u0947\u0915\u094d\u091f \u092e\u0947\u0902 \u092e\u094c\u091c\u0942\u0926 \u0939\u0948\u0964 \u0926\u0942\u0938\u0930\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f \u092f\u093e \u092b\u093c\u094b\u091f\u094b \u0915\u0947 \u0938\u093e\u0925 \u092b\u093c\u093f\u0930 \u0938\u0947 \u0915\u094b\u0936\u093f\u0936 \u0915\u0930\u0947\u0902, \u092f\u093e \u0928\u0940\u091a\u0947 \u0921\u0947\u092e\u094b \u0916\u094b\u0932\u0947\u0902 \u092e\u0947\u091f\u093e\u0921\u0947\u091f\u093e \u0905\u092a\u0921\u0947\u091f \u0915\u0930\u0928\u0947 \u092f\u093e \u092e\u094c\u091c\u0942\u0926\u093e \u0928\u093e\u092e\u093e\u0902\u0915\u0928 \u0939\u091f\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f\u0964",
  "imagesHeading": "\u091c\u093f\u0928 \u091b\u0935\u093f\u092f\u094b\u0902 \u0915\u094b \u0906\u092a \u0928\u093e\u092e\u093e\u0902\u0915\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u0940 \u0915\u094b\u0936\u093f\u0936 \u0915\u0940",
  "nextSteps": "\u0905\u0917\u0932\u0947 \u0915\u0926\u092e",
