{
  "name": "desktop",
  "version": "1.0.0",
  "private": true,
  "description": "HumanAuthn Desktop — Verifik biometric authentication demo",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm web:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "web:dev": "cd ../web && pnpm dev",
    "build": "cd ../web && pnpm build && electron-builder",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "co.verifik.humanauthn",
    "productName": "HumanAuthn",
    "copyright": "Copyright © 2024 Verifik",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb"]
    },
    "files": [
      "electron/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      { "from": "../web/.next", "to": "web/.next" },
      { "from": "../web/public", "to": "web/public" },
      { "from": "../web/package.json", "to": "web/package.json" }
    ]
  }
}
